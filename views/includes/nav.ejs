<!-- Navbar principal compartilhada entre as paginas. -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container-fluid">
    <a class="navbar-brand" href="/">Projeto Agenda</a>
    <!-- Links principais de navegacao. -->
    <div class="ms-auto">
      <ul class="navbar-nav ms-auto">
        <% if (!usuario) { %>
          <li class="nav-item">
            <a class="nav-link" href="/login/index">Login</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/login/index">Registre-se</a>
          </li>
        <% } else { %>
          <li class="nav-item">
            <span class="nav-link">Logado: <%= usuario.email %></span>
          </li>
          <li class="nav-item">
            <form action="/login/logout" method="POST" class="d-flex align-items-center">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="nav-link btn btn-link p-0 ms-2">Sair</button>
            </form>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
