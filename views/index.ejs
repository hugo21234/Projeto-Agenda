<%#
  Arquivo: views/index.ejs
  Papel: página inicial da aplicação (dashboard simples da agenda).
  Conexão: renderizado por `homeController.index` e reutiliza includes de layout.
%>
<%- include('includes/head', { titulo }) %>
<%- include('includes/nav') %>
<%- include('includes/messages') %>

<div class="container">
  <div class="row">
    <div class="col-lg-2"></div>

    <div class="col-lg-8 my-3">
      <h1 class="display-1 text-center">Agenda</h1>
      <p class="text-center lead">Seus contatos estão abaixo</p>

      <div class="d-flex justify-content-center mb-3">
        <a href="/criar-contato/index" class="btn btn-primary">Criar novo contato</a>
      </div>

      <% if (contatos && contatos.length > 0) { %>
        <ul class="list-group">
          <% contatos.forEach((contato) => { %>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <div>
                <strong><%= contato.nome %></strong><br>
                <small><%= contato.email %></small>
              </div>
              <div class="d-flex gap-3 align-items-center">
                <span><%= contato.number %></span>
                <a href="/contato/index/<%= contato._id %>">editar</a>
                <a class="text-danger" href="/contato/delete/<%= contato._id %>">excluir</a>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p class="text-center text-muted">Nenhum contato cadastrado.</p>
      <% } %>
    </div>

    <div class="col-lg-2"></div>
  </div>
</div>

<%- include('includes/footer') %>
